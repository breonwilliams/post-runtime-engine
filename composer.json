{
    "name": "developer/post-runtime-engine",
    "description": "A WordPress plugin that renders custom-post-type single pages with structured data display through Promptless WP's design system.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0",
        "brain/monkey": "^2.6"
    },
    "autoload-dev": {
        "psr-4": {
            "PRE\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "@test:unit",
            "@test:integration"
        ],
        "test:unit": "TEST_SUITE=unit ./vendor/bin/phpunit --testsuite Unit",
        "test:integration": "TEST_SUITE=integration WP_TESTS_DIR=${WP_TESTS_DIR:-/tmp/wordpress-tests-lib} ./vendor/bin/phpunit --testsuite Integration",
        "test:coverage": "TEST_SUITE=unit ./vendor/bin/phpunit --testsuite Unit --coverage-text",
        "install-wp-tests": "bash bin/install-wp-tests.sh"
    }
}
